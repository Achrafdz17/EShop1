@model MyWebApp.Models.Product
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="text-center mb-4">➕ إضافة منتج جديد</h2>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card p-4">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label class="form-label">اسم المنتج</label>
                    <input asp-for="Name" class="form-control bg-dark text-white border-secondary" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">التصنيف</label>
                    <select asp-for="Category" class="form-control bg-dark text-white border-secondary" required>
                        <option value="">-- اختر التصنيف --</option>
                        <option value="إلكترونيات">📱 إلكترونيات</option>
                        <option value="ملابس">👕 ملابس</option>
                        <option value="سيارات">🚗 سيارات</option>
                        <option value="أثاث">🛋️ أثاث</option>
                        <option value="أخرى">📦 أخرى</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">الوصف</label>
                    <textarea asp-for="Description" class="form-control bg-dark text-white border-secondary" rows="3"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">السعر (دج)</label>
                    <input asp-for="Price" type="number" step="0.01"
                           class="form-control bg-dark text-white border-secondary" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">صورة المنتج</label>
                    <input type="file" name="ImageFile" accept="image/*"
                           class="form-control bg-dark text-white border-secondary" />
                </div>
                <button type="submit" class="btn btn-primary w-100">💾 حفظ المنتج</button>
            </form>
        </div>
    </div>
</div>