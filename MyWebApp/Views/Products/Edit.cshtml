@model MyWebApp.Models.Product
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="text-center mb-4">✏️ تعديل المنتج</h2>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card p-4">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <input asp-for="Id" type="hidden" />
                <div class="mb-3">
                    <label class="form-label">اسم المنتج</label>
                    <input asp-for="Name" class="form-control bg-dark text-white border-secondary" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">الوصف</label>
                    <textarea asp-for="Description" class="form-control bg-dark text-white border-secondary" rows="3"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">السعر (دج)</label>
                    <input asp-for="Price" type="number" step="0.01"
                           class="form-control bg-dark text-white border-secondary" required />
                </div>
                @if (!string.IsNullOrEmpty(Model.ImagePath))
                {
                    <div class="mb-3">
                        <img src="@Model.ImagePath" style="height:100px; border-radius:10px;" />
                    </div>
                }
                <div class="mb-3">
                    <label class="form-label">تغيير الصورة (اختياري)</label>
                    <input type="file" name="ImageFile" accept="image/*"
                           class="form-control bg-dark text-white border-secondary" />
                </div>
                <button type="submit" class="btn btn-primary w-100">💾 حفظ التعديلات</button>
            </form>
        </div>
    </div>
</div>