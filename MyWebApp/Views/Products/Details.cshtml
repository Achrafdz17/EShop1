@model MyWebApp.Models.Product
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card p-4 text-center">
            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <img src="@Model.ImagePath" style="height:250px; object-fit:cover; border-radius:15px;" class="mb-4" />
            }
            <h2>@Model.Name</h2>
            <p class="mt-3">@Model.Description</p>
            <p class="fw-bold fs-4" style="color:#cc88ff;">💰 @Model.Price دج</p>
            <div class="mt-4">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning me-2">✏️ تعديل</a>
                <a asp-action="Index" class="btn btn-primary">🔙 رجوع</a>
            </div>
        </div>
    </div>
</div>